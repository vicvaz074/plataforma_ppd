    "autoprefixer": "^10.4.20",
    "bcryptjs": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.4",
    "cookie": "latest",
    "crypto": "latest",
    "date-fns": "latest",
    "docx": "^9.5.1",
    "embla-carousel-react": "8.5.1",
    "express": "5.2.1",
    "file-saver": "^2.0.5",
    "framer-motion": "latest",
