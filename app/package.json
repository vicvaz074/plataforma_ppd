{
  "name": "my-v0-project",
  "version": "0.1.10",
  "description": "Aplicación de privacidad y gobernanza de datos",
  "author": "Vicente Vázquez",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "build:electron": "NEXT_TARGET=electron next build",
    "serve": "serve out -l 3000",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:prod": "NODE_ENV=production electron .",
    "pack": "electron-builder --mac --dir",
    "dist": "electron-builder --mac",
    "analyze": "ANALYZE=true next build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "semgrep": "semgrep scan --config .semgrep.yaml --metrics=off . || true",
    "test": "node --experimental-strip-types --test",
    "test:e2e": "NODE_ENV=production node --experimental-strip-types --test tests/e2e/security.test.js"
  },
  "build": {
    "appId": "com.vicentevazquez.myproject",
    "productName": "DavaraGovernance",
    "files": [
      "main.js",
      "out/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public"
    },
    "mac": {
      "target": [
        "pkg"
      ],
      "category": "public.app-category.productivity"
    }
  },
  "dependencies": {
    "@emotion/is-prop-valid": "latest",
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-accordion": "latest",
