# ─── Seguridad ────────────────────────────────────────────────────────────────

# Email del administrador principal
ADMIN_EMAIL=admin@example.com

# Hash bcrypt del password del admin (generar con: npx bcryptjs hash "tu-password")
# IMPORTANTE: En producción, NUNCA usar el password por defecto
ADMIN_PASSWORD_HASH=$2b$12$...tu-hash-aqui...

# Solo para bootstrap local controlado; sustituir por hash bcrypt en producción
ADMIN_PASSWORD_PLAIN=password

# Secreto para firmar cookies de sesión (generar con: openssl rand -base64 32)
SESSION_SECRET=genera-un-secreto-seguro-aqui

# Duración de la sesión en horas (default: 5)
SESSION_DURATION_HOURS=5

# ─── Aplicación ───────────────────────────────────────────────────────────────

# Entorno de ejecución
NODE_ENV=production

# Puerto de escucha de la aplicación web en despliegue on-premise
PORT=3000

# URL pública de la aplicación (para CORS y redirecciones)
NEXT_PUBLIC_APP_URL=https://davara.interno

# URL corporativa que puede consumir el cliente Electron en modo on-premise
DAVARA_SERVER_URL=https://davara.interno

# Mantener deshabilitado por defecto el asistente externo en entornos on-premise
NEXT_PUBLIC_ENABLE_EXTERNAL_ASSISTANT=false

# ─── Persistencia central y sincronización híbrida ───────────────────────────

# PostgreSQL on-premise
DATABASE_URL=postgresql://davara:davara@postgres:5432/davara_onprem

# Límite sugerido por lote de sincronización
SYNC_BATCH_SIZE=50

# Intervalo sugerido de reintento automático de sincronización (ms)
SYNC_RETRY_INTERVAL_MS=15000

# Retención sugerida de respaldos
BACKUP_RETENTION_DAYS=14

# ─── TLS/SSL (para despliegue on-premise) ────────────────────────────────────

# Ruta al certificado TLS
# TLS_CERT_PATH=/etc/ssl/certs/app.crt

# Ruta a la clave privada TLS
# TLS_KEY_PATH=/etc/ssl/private/app.key

# ─── Almacenamiento (producción) ─────────────────────────────────────────────

# Directorio on-premise donde se almacenan uploads server-side
UPLOADS_DIR=/app/uploads

# Directorio sugerido para logs de aplicación
# LOG_DIR=/app/logs
