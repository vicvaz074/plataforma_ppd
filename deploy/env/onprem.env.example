NODE_ENV=production
PORT=3000
HTTPS_PORT=443

NEXT_PUBLIC_APP_URL=https://davara.interno
NEXT_PUBLIC_ENABLE_EXTERNAL_ASSISTANT=false
SYNC_BATCH_SIZE=50
SYNC_RETRY_INTERVAL_MS=15000
BACKUP_RETENTION_DAYS=14

# Ruta interna de uploads dentro del contenedor
UPLOADS_DIR=/app/uploads

# Puede ser usada por Electron cuando se despliega contra la URL corporativa
DAVARA_SERVER_URL=https://davara.interno

POSTGRES_DB=davara_onprem
POSTGRES_USER=davara
POSTGRES_PASSWORD=davara
DATABASE_URL=postgresql://davara:davara@postgres:5432/davara_onprem

# Reemplazar por valores reales del cliente
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=REEMPLAZAR_POR_HASH_BCRYPT_REAL
ADMIN_PASSWORD_PLAIN=password
SESSION_SECRET=reemplazar_por_secreto_largo_y_aleatorio
